    DestroyAllESP()
    
    for _, conn in ipairs(connections) do
        pcall(function() conn:Disconnect() end)
    end
    connections = {}
    
    if screenGui then
        pcall(function() screenGui:Destroy() end)
    end
    
    espEnabled = nil
    showSelf = nil
    showOthers = nil
    showNames = nil
    CurrentColor = nil
    espObjects = nil
    playersProcessing = nil
    
    collectgarbage()
    
    print("💎 ESP полностью выгружен! Все функции отключены.")
end

