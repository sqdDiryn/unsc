        root.CFrame = CFrame.new(pos.X, pos.Y + 3, pos.Z, select(4, root.CFrame:components()))
        breakVelocity()
    end)
    notify("Предметы", "Tptool выдан!")
end

-- Функция телепортации к игроку
local function TeleportToPlayer(playerName)
    local targetPlayer = nil
    for _, player in ipairs(Players:GetPlayers()) do
        if string.lower(player.Name) == string.lower(playerName) then
            targetPlayer = player
            break
        end
    end
    
    if not targetPlayer then
        teleportInput.Text = "❌ Игрок не найден!"
        task.wait(1)
        teleportInput.Text = ""
        teleportInput.PlaceholderText = "Введите ник игрока..."
        return
    end
    
    if targetPlayer == LocalPlayer then
        teleportInput.Text = "❌ Это вы!"
        task.wait(1)
        teleportInput.Text = ""
        teleportInput.PlaceholderText = "Введите ник игрока..."
        return
    end
    
    local character = targetPlayer.Character
    if not character then
        teleportInput.Text = "❌ Игрок не в игре!"
        task.wait(1)
        teleportInput.Text = ""
        teleportInput.PlaceholderText = "Введите ник игрока..."
        return
    end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then
        teleportInput.Text = "❌ Ошибка!"
        task.wait(1)
        teleportInput.Text = ""
        teleportInput.PlaceholderText = "Введите ник игрока..."
        return
    end
    
    local localChar = LocalPlayer.Character
    if not localChar then
        teleportInput.Text = "❌ У вас нет персонажа!"
        task.wait(1)
        teleportInput.Text = ""
        teleportInput.PlaceholderText = "Введите ник игрока..."
        return
    end
    
    local localRoot = getRoot(localChar)
    if not localRoot then
        teleportInput.Text = "❌ Ошибка!"
        task.wait(1)
        teleportInput.Text = ""
        teleportInput.PlaceholderText = "Введите ник игрока..."
        return
    end
    
    localRoot.CFrame = rootPart.CFrame + Vector3.new(0, 3, 0)
    breakVelocity()
    teleportInput.Text = "✅ Телепорт успешен!"
    task.wait(1)
    teleportInput.Text = ""
    teleportInput.PlaceholderText = "Введите ник игрока..."
end

